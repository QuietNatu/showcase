{
  "name": "showcase",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "cross-env VITE_E2E=true playwright test",
    "e2e:debug": "cross-env PWDEBUG=1 VITE_E2E=true playwright test",
    "lint": "npm run lint:lslint && npm run lint:eslint && npm run lint:stylelint && npm run lint:prettier && npm run lint:dependencies",
    "lint:lslint": "ls-lint",
    "lint:eslint": "eslint --max-warnings=0 src/**/*.{ts,tsx}",
    "lint:stylelint": "stylelint src/**/*.{css,scss}",
    "lint:prettier": "prettier --check src/**/*.{js,jsx,ts,tsx,json,css,scss,md}",
    "lint:dependencies": "depcruise src --config .dependency-cruiser.cjs",
    "prepare": "husky install",
    "graph:modules": "depcruise src --config graphs/.modules.cjs -T dot | dot -T svg | depcruise-wrap-stream-in-html > graphs/modules-graph.html"
  },
  "dependencies": {
    "clsx": "1.2.1",
    "date-fns": "2.29.3",
    "fp-ts": "2.13.1",
    "rambda": "7.4.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "url-join": "5.0.0",
    "workbox-core": "6.5.4",
    "workbox-expiration": "6.5.4",
    "workbox-precaching": "6.5.4",
    "workbox-routing": "6.5.4",
    "workbox-strategies": "6.5.4",
    "workbox-window": "6.5.4"
  },
  "devDependencies": {
    "@commitlint/cli": "17.4.4",
    "@commitlint/config-conventional": "17.4.4",
    "@ls-lint/ls-lint": "1.11.2",
    "@mswjs/data": "0.11.2",
    "@playwright/test": "1.29.1",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "13.4.0",
    "@testing-library/user-event": "14.4.3",
    "@types/chance": "1.1.3",
    "@types/react": "18.0.26",
    "@types/react-dom": "18.0.10",
    "@typescript-eslint/eslint-plugin": "5.47.1",
    "@typescript-eslint/parser": "5.47.1",
    "@vitejs/plugin-react": "3.0.1",
    "@vitest/coverage-istanbul": "0.26.2",
    "axe-core": "4.6.3",
    "chance": "1.1.10",
    "cross-env": "7.0.3",
    "dependency-cruiser": "12.9.0",
    "dotenv": "16.0.3",
    "eslint": "8.34.0",
    "eslint-config-prettier": "8.6.0",
    "eslint-import-resolver-typescript": "3.5.3",
    "eslint-plugin-functional": "5.0.4",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-jest": "27.2.1",
    "eslint-plugin-jest-dom": "4.0.3",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-playwright": "0.12.0",
    "eslint-plugin-react": "7.32.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-testing-library": "5.10.1",
    "eslint-plugin-unused-imports": "2.0.0",
    "husky": "8.0.3",
    "jest-axe": "7.0.0",
    "jsdom": "20.0.3",
    "lint-staged": "13.1.2",
    "msw": "0.49.3",
    "playwright": "1.29.1",
    "prettier": "2.8.4",
    "rollup-plugin-visualizer": "5.9.0",
    "sass": "1.57.1",
    "stylelint": "14.16.1",
    "stylelint-config-css-modules": "4.1.0",
    "stylelint-config-prettier": "9.0.4",
    "stylelint-config-standard-scss": "6.1.0",
    "stylelint-order": "5.0.0",
    "stylelint-scss": "4.3.0",
    "type-fest": "3.5.7",
    "typescript": "4.9.5",
    "vite": "4.0.3",
    "vite-plugin-pwa": "0.14.4",
    "vite-plugin-svgr": "2.4.0",
    "vite-tsconfig-paths": "4.0.5",
    "vitest": "0.26.2"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
