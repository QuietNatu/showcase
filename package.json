{
  "name": "showcase",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "18.x",
    "npm": "9.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "cross-env VITE_E2E=true playwright test",
    "e2e:debug": "cross-env PWDEBUG=1 VITE_E2E=true playwright test",
    "lint": "npm run lint:lslint && npm run lint:eslint && npm run lint:stylelint && npm run lint:prettier && npm run lint:dependencies",
    "lint:lslint": "ls-lint",
    "lint:eslint": "eslint --max-warnings=0 src/**/*.{ts,tsx}",
    "lint:stylelint": "stylelint src/**/*.{css,scss}",
    "lint:prettier": "prettier --check src/**/*.{js,jsx,ts,tsx,json,css,scss,md}",
    "lint:dependencies": "depcruise src --config .dependency-cruiser.cjs",
    "prepare": "husky install",
    "graph:modules": "depcruise src --config graphs/.modules.cjs -T dot | dot -T svg | depcruise-wrap-stream-in-html > graphs/modules-graph.html"
  },
  "dependencies": {
    "@csstools/normalize.css": "12.0.0",
    "clsx": "1.2.1",
    "date-fns": "2.29.3",
    "fp-ts": "2.13.1",
    "rambda": "7.4.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "url-join": "5.0.0",
    "workbox-core": "6.5.4",
    "workbox-expiration": "6.5.4",
    "workbox-precaching": "6.5.4",
    "workbox-routing": "6.5.4",
    "workbox-strategies": "6.5.4",
    "workbox-window": "6.5.4"
  },
  "devDependencies": {
    "@commitlint/cli": "17.4.4",
    "@commitlint/config-conventional": "17.4.4",
    "@ls-lint/ls-lint": "1.11.2",
    "@mswjs/data": "0.11.2",
    "@playwright/test": "1.31.1",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "14.0.0",
    "@testing-library/user-event": "14.4.3",
    "@types/chance": "1.1.3",
    "@types/react": "18.0.28",
    "@types/react-dom": "18.0.11",
    "@typescript-eslint/eslint-plugin": "5.52.0",
    "@typescript-eslint/parser": "5.52.0",
    "@vitejs/plugin-legacy": "4.0.1",
    "@vitejs/plugin-react": "3.1.0",
    "@vitest/coverage-istanbul": "0.28.5",
    "autoprefixer": "10.4.14",
    "axe-core": "4.6.3",
    "chance": "1.1.10",
    "cross-env": "7.0.3",
    "dependency-cruiser": "12.10.0",
    "dotenv": "16.0.3",
    "eslint": "8.34.0",
    "eslint-config-prettier": "8.6.0",
    "eslint-import-resolver-typescript": "3.5.3",
    "eslint-plugin-functional": "5.0.4",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-jest": "27.2.1",
    "eslint-plugin-jest-dom": "4.0.3",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-playwright": "0.12.0",
    "eslint-plugin-react": "7.32.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-testing-library": "5.10.2",
    "eslint-plugin-unused-imports": "2.0.0",
    "husky": "8.0.3",
    "jest-axe": "7.0.0",
    "jsdom": "21.1.0",
    "lint-staged": "13.1.2",
    "msw": "1.0.1",
    "playwright": "1.31.1",
    "postcss-preset-env": "8.0.1",
    "prettier": "2.8.4",
    "rollup-plugin-visualizer": "5.9.0",
    "sass": "1.58.3",
    "stylelint": "15.2.0",
    "stylelint-config-css-modules": "4.2.0",
    "stylelint-config-standard-scss": "7.0.1",
    "stylelint-order": "6.0.2",
    "stylelint-scss": "4.4.0",
    "type-fest": "3.6.0",
    "typescript": "4.9.5",
    "vite": "4.1.4",
    "vite-plugin-pwa": "0.14.4",
    "vite-plugin-svgr": "2.4.0",
    "vite-tsconfig-paths": "4.0.5",
    "vitest": "0.28.5"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
